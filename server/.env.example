# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prime_billiard
DB_USER=postgres
DB_PASS=
# Boshqariladigan/masofaviy PostgreSQL (TLS talab qiladigan) uchun true qiling.
# Production da shifrlangan ulanish TAVSIYA etiladi. Faqat NODE_ENV=production da amal qiladi.
DB_SSL=false

# JWT — kuchli tasodifiy qiymatlar QO'YISH SHART:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend manzili (CORS uchun). Production: haqiqiy domen, masalan https://billiardclub.uz
FRONTEND_URL=http://localhost:5173

# Reverse proxy (nginx/Caddy) ORTIDA ishlatsangiz — MAJBURIY true qiling.
# Aks holda rate-limit va login blokirovkasi barcha foydalanuvchilarni bitta
# proxy IP si deb ko'radi (X-Forwarded-For orqali haqiqiy IP olinmaydi).
TRUST_PROXY=false

# Telegram bot — yangi klub qo'shilganda va obuna uzaytirilganda sizga xabar boradi.
# 1) @BotFather da bot yarating, tokenini oling
# 2) Botga /start yozing
# 3) https://api.telegram.org/bot<TOKEN>/getUpdates dan chat.id ni oling
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Superadmin — `npm run seed` birinchi ishga tushirishda yaratadi
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=

# Dev: demo klub yaratilsinmi (production da hech qachon true qilmang)
SEED_DEMO_CLUB=false
