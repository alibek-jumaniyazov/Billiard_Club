# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prime_billiard
DB_USER=postgres
DB_PASS=

# JWT — kuchli tasodifiy qiymatlar QO'YISH SHART:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# Frontend manzili (CORS uchun)
FRONTEND_URL=http://localhost:5173

# Telegram bot — yangi klub qo'shilganda va obuna uzaytirilganda sizga xabar boradi.
# 1) @BotFather da bot yarating, tokenini oling
# 2) Botga /start yozing
# 3) https://api.telegram.org/bot<TOKEN>/getUpdates dan chat.id ni oling
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Superadmin — `npm run seed` birinchi ishga tushirishda yaratadi
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=

# Dev: demo klub yaratilsinmi (production da hech qachon true qilmang)
SEED_DEMO_CLUB=false
